{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/indexer/dex/v1/check_lp_tokens", "destination": "/api/indexer/dex/v1/check_lp_tokens" },
    { "source": "/indexer/:path*", "destination": "/api/indexer-stub" },
    { "source": "/v2/(.*)", "destination": "/api/v2" },
    { "source": "/((?!api|assets|indexer|chains\\.json|profiles\\.json).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    },
    {
      "source": "/(chains|profiles)\\.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=60" }
      ]
    }
  ]
}
